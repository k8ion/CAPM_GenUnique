<mvc:View
    controllerName="uuidgenerator.controller.GenU"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="_IDGenPage"
        title="UUID Generator"
    >
        <content>
            <VBox
                id="_IDGenVBox"
                class="sapUiSmallMargin"
            >
                <Label
                    id="_IDGenLabel"
                    text="Number of Records"
                    labelFor="numInput"
                />
                <StepInput
                    id="numInput"
                    value="5"
                    min="1"
                    width="120px"
                    textAlign="Center"
                />
                <Button
                    id="_IDGenButton"
                    text="Generate UUIDs"
                    press="onGeneratePress"
                    type="Emphasized"
                />

                <!-- Add a base binding path so the template is recognized -->
                <!-- When you write items="{/UUIDs}" in the XML, 
                    UI5 looks at your OData metadata and sees UUIDs as a collection (Entity Set) it can query from the database -->
                <Table
                    id="uuidTable"
                    items="{/UUIDs}"
                    growing="true"
                    growingThreshold="100"
                    growingScrollToLoad="true"
                >
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenOverflowToolbar1">
                            <Title
                                id="_IDGenTitle"
                                text="Generated UUIDs Records"
                            />
                            <ToolbarSpacer id="_IDGenToolbarSpacer" />
                            <Button
                                id="_IDGenButton1"
                                icon="sap-icon://excel-attachment"
                                press="onExport"
                                tooltip="Export to Excel"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column
                            id="_IDGenColumn"
                            width="80px"
                        >
                            <Text
                                id="_IDGenText1"
                                text="Sr. No."
                            />
                        </Column>
                        <Column id="_IDGenColumn1">
                            <Text
                                id="_IDGenText2"
                                text="UUID"
                            />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem id="_IDGenColumnListItem">
                            <cells>
                                <!-- We will fix Sr. No. once binding works -->
                                <Text
                                    id="_IDGenText3"
                                    text="{ path: 'ID', formatter: '.formatter.formatSrNo' }"
                                />
                                <Text
                                    id="_IDGenText4"
                                    text="{ID}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
